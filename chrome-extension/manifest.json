{
  "manifest_version": 3,
  "name": "울산대학교 업무 도우미",
  "version": "1.1",
  "description": "그룹웨어 사용 중 실시간 업무 가이드를 제공합니다",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
